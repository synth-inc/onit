    "Works together with top-k. A higher value (e.g., 0.95) will lead to more diverse text, while a lower value (e.g., 0.5) will generate more focused and conservative text": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Works together with top-k. A higher value (e.g., 0.95) will lead to more diverse text, while a lower value (e.g., 0.5) will generate more focused and conservative text"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fonctionne avec top-k. Une valeur plus élevée (ex. 0.95) produira un texte plus diversifié, tandis qu'une valeur plus basse (ex. 0.5) générera un texte plus ciblé et conservateur"
          }
        }
      }
    },
