          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Onit apparaîtra toujours sur le côté droit de votre écran. Vous n'aurez qu'un seul panneau Onit à la fois. Les autres applications seront redimensionnées pour faire place à Onit."
