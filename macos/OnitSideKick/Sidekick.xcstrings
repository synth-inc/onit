      }
    },
    "Automatically loads highlighted text as content. When enabled, Onit will read highlighted text from any application, and add it as context to your conversation. Context is not uploaded until you submit your conversation. In local mode, no context is ever uploaded." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatically loads highlighted text as content. When enabled, Onit will read highlighted text from any application, and add it as context to your conversation. Context is not uploaded until you submit your conversation. In local mode, no context is ever uploaded."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Charge automatiquement le texte surligné comme contenu. Lorsqu'activé, Onit lira le texte surligné depuis n'importe quelle application et l'ajoutera comme contexte à votre conversation. Le contexte n'est pas envoyé tant que vous ne soumettez pas votre conversation. En mode local, aucun contexte n'est jamais envoyé."
          }
        }
      }
    },
